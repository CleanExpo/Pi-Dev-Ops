{
  "name": "@unite-group/brand-config",
  "version": "0.1.0",
  "description": "Single source of truth for Unite-Group brand configs (DR, NRPG, RestoreAssist, CARSI, CCW, Synthex, Unite). Plus themeFactory for Tailwind / CSS-var consumption in web apps.",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./theme-factory": {
      "import": "./dist/theme-factory.js",
      "require": "./dist/theme-factory.cjs",
      "types": "./dist/theme-factory.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/theme-factory.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/theme-factory.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.0"
  }
}
