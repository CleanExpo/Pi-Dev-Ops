# ─── Authentication ──────────────────────────────────────────────────────────
# Required. Strong password for the Pi-CEO dashboard.
TAO_PASSWORD=changeme

# Optional. Auto-generated and persisted to app/data/.session-secret on first run.
# Set explicitly to keep sessions alive across redeploys.
TAO_SESSION_SECRET=

# ─── Model provider routing ──────────────────────────────────────────────────
# Required for non-Claude-CLI/default runtime. Pi-Dev-Ops uses Anthropic/Claude
# Code workflow methods, but non-Claude CLI/API execution should use
# OpenAI-compatible providers/models so we do not pay Anthropic API credits.
OPENROUTER_API_KEY=sk-or-...

# Default model routing. Override these if provider model IDs change.
TAO_TOP_MODEL=openai/gpt-5.5
TAO_MID_MODEL=openai/gpt-5.5
TAO_CHEAP_REMOTE_MODEL=moonshotai/kimi-k2.5
TAO_GPT55_MODEL=openai/gpt-5.5
TAO_KIMI25_MODEL=moonshotai/kimi-k2.5

# Legacy fallback only. Do not set for normal operation unless explicitly approved.
ANTHROPIC_API_KEY=

# Claude CLI / Anthropic Max Plan mode only. Safe when the machine is logged in
# with Claude Max/OAuth and calls go through `claude --print`, not Anthropic API
# credits. Leave off for other CLI/provider runtimes.
TAO_TOP_USE_CLAUDE_PRINT=0
TAO_MID_USE_CLAUDE_PRINT=0

# ─── Linear ──────────────────────────────────────────────────────────────────
# Required for Pi-SEO triage and MCP tools. Linear API key (starts with lin_api_).
LINEAR_API_KEY=lin_api_...

# Optional. Secret for Linear webhook signature verification.
TAO_LINEAR_WEBHOOK_SECRET=

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Optional. GitHub PAT for webhook auth (ghp_...).
TAO_WEBHOOK_SECRET=
GITHUB_TOKEN=ghp_...

# ─── Telegram ────────────────────────────────────────────────────────────────
# Telegram bot token (from @BotFather).
TELEGRAM_BOT_TOKEN=

# Separate secret passed as secret_token when calling setWebhook.
# Must match X-Telegram-Bot-Api-Secret-Token header Telegram sends.
TELEGRAM_WEBHOOK_SECRET=

# ─── Server ──────────────────────────────────────────────────────────────────
TAO_HOST=127.0.0.1
TAO_PORT=7777
# Max concurrent Claude build sessions (default: 3)
TAO_MAX_SESSIONS=3
# API rate limit per IP per minute (default: 30)
TAO_RATE_LIMIT=30

# ─── Evaluator ───────────────────────────────────────────────────────────────
TAO_EVALUATOR_ENABLED=true
TAO_EVALUATOR_MODEL=sonnet
TAO_EVALUATOR_THRESHOLD=8
TAO_EVALUATOR_MAX_RETRIES=2

# ─── Pi-SEO Scanner ──────────────────────────────────────────────────────────
# Root directory where repos are cloned for scanning (default: ~/pi-seo-workspace)
SCAN_WORKSPACE_ROOT=~/pi-seo-workspace

# ─── Pi-SEO Production Gate (RA-586) ─────────────────────────────────────────
# Set to 1 to enable live scan + monitor cron triggers across all 11 repos.
# Default: 0 (safe — scans are disabled until explicitly activated).
PI_SEO_ACTIVE=0

# ─── Telegram Alert Channel (RA-586) ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN: same bot token used by the Railway Telegram bot
# TELEGRAM_ALERT_CHAT_ID: Phill's Telegram user ID (receives critical Pi-SEO finding alerts)
TELEGRAM_ALERT_CHAT_ID=

# ─── API Fallback (Risk Register R-02, RA-634) ───────────────────────────────
# FALLBACK ONLY — do NOT set this to 1 in normal operation.
# When TAO_USE_FALLBACK=1, build sessions use the Anthropic Python SDK directly
# (requests to api.anthropic.com using ANTHROPIC_API_KEY) instead of the claude CLI.
# Used by scripts/fallback_dryrun.py to verify the fallback path works quarterly.
# See DEPLOYMENT.md → "Contingency: API Fallback" for procedures.
TAO_USE_FALLBACK=0

# ─── Supabase server-side writes (RA-651, RA-633) ────────────────────────────
# Required for gate_checks and alert_escalations logging from the FastAPI server.
# NEXT_PUBLIC_SUPABASE_URL — same value used by the dashboard frontend
# SUPABASE_SERVICE_ROLE_KEY — service-role secret (bypasses RLS; never expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://zbryrmxmgfmslqzizsto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Frontend (dashboard/.env.local) ─────────────────────────────────────────
# URL of the running Pi-CEO FastAPI backend
PI_CEO_URL=http://127.0.0.1:7777
# Same password as TAO_PASSWORD above — used by Next.js proxy for server-side auth
PI_CEO_PASSWORD=
# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
