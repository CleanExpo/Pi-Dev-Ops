# Copy to ~/.supervisor.env on each machine and edit.
#
# Machine A — this Mac (Pi-Dev-Ops / Pi-CEO work):
#   PROJECT_DIR=/Users/phill-mac/Pi-CEO/Pi-Dev-Ops
#   SESSION=pidevops
#   MACHINE=mac-mini-ceo
#
# Machine B — CCW-CRM work:
#   PROJECT_DIR=/Users/<user>/dev/CCW-CRM
#   SESSION=ccw
#   MACHINE=mac-ccw
#
# Machine C — RestoreAssist work:
#   PROJECT_DIR=/Users/<user>/dev/RestoreAssist
#   SESSION=restoreassist
#   MACHINE=mac-ra

PROJECT_DIR=/path/to/your/repo
SESSION=myproject
MACHINE=$(hostname -s)

# Optional: push each nudge event to Pi-CEO's dashboard so you can watch all 3
# machines from one place. Leave commented out until RA-1291 Phase 2 ships the
# /api/supervisor/checkin endpoint.
# CHECKIN_URL=https://pi-dev-ops-production.up.railway.app/api/supervisor/checkin
# CHECKIN_KEY=your-bearer-token

# Tuning
STALL_SECONDS=30
MAX_NUDGES=20
