    "eslint-config-next": "^16.2.0",
    "eslint-formatter-compact": "^9.0.1",
    "glob": "^11.0.3",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "lint-staged": "^15.2.0",
