    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "22.x"
  },
  "eslintConfig": {
    "extends": "next/core-web-vitals",
    "rules": {
      "react/no-unescaped-entities": "off",
      "@next/next/no-img-element": "off",
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error",
            "debug",
            "info"
          ]
        }
      ]
    }
  },
  "overrides": {
    "protobufjs": "^7.5.8",
    "uuid": "^14.0.0",
    "postcss": "^8.5.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
