    "@number-flow/react": "^0.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
