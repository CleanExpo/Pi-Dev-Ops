  storiesReviewed   Int     @default(0) @map("stories_reviewed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("story_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI Marketing Advisor — SYN-593
// ─────────────────────────────────────────────────────────────────────────────

/// Weekly personalised AI marketing brief — 3 ranked recommended actions per client.
/// Generated every Monday 07:00 AEDT. Held as status=generated for 7-day quality gate
/// before delivery automation fires.
model RecommendedAction {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  /// Monday of the week this brief covers (date only, UTC)
  weekStart DateTime @map("week_start") @db.Date

  /// Exactly 3 ranked action objects — see ActionItem type in lib/advisor/types.ts
  actions Json

  /// Human-readable attribution: "Synthex contributed to N enquiries and ~$X in potential revenue"
  dollarAttribution String @map("dollar_attribution") @db.Text

  /// Number used in dollar attribution sentence
  jobCountAttribution Int @default(0) @map("job_count_attribution")

  /// One-sentence competitor gap signal. Null if data unavailable.
  competitorMicroInsight String? @map("competitor_micro_insight") @db.Text

  /// GEO baseline teaser row. Null if no GEO data present.
  geoTeaserText String? @map("geo_teaser_text") @db.Text

  /// Results summary: { postsPublished, bestPostId, authorityScoreDelta, revenueAttributed }
  resultsSummary Json @map("results_summary")

  /// generated → held for quality review; delivered → sent to client; read → opened; archived
  status String @default("generated")

  /// ROI attribution context — SYN-623
  /// Shape: { content_id?, content_type?, predicted_conversion_probability?, utm_params?, attribution_window_days? }
  /// Populated by AI Advisor for actions involving content publishing or review responses.
  /// Consumed by Sprint 6 ROI Attribution Dashboard (SYN-624).
  attributionContext Json? @default("{}") @map("attribution_context")

  createdAt   DateTime  @default(now()) @map("created_at")
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, weekStart], name: "recommended_action_org_week")
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([status])
  @@map("recommended_actions")
}

/// Weekly advisor feedback — SYN-594
model AdvisorFeedback {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  weekStart      DateTime @map("week_start") @db.Date

  /// 'useful' | 'not_useful' | 'skipped'
  response       String

  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, weekStart], name: "advisor_feedback_org_week")
  @@index([organizationId])
  @@index([weekStart])
  @@map("advisor_feedback")
}

/// RBAC team membership — SYN-598
/// Two active roles: 'owner' | 'collaborator'. 'viewer' reserved for Sprint 5.
model TeamMember {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  organizationId String    @map("organization_id")

  /// 'owner' | 'collaborator' | 'viewer'
  role           String

  invitedBy      String?   @map("invited_by")
  invitationId   String?   @map("invitation_id")

  invitedAt      DateTime  @default(now()) @map("invited_at")
  acceptedAt     DateTime? @map("accepted_at")

  /// Null until first dashboard visit — used to trigger the context screen
  lastActiveAt              DateTime? @map("last_active_at")

  /// Null until first weekly-active event fires. Used for 7-day deduplication.
  lastWeeklyActiveFiredAt   DateTime? @map("last_weekly_active_fired_at")

  user           User                  @relation("TeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter        User?                 @relation("TeamMemberInviter", fields: [invitedBy], references: [id], onDelete: SetNull)
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pageViews      TeamMemberPageView[]

  @@unique([userId, organizationId], name: "team_member_user_org")
  @@index([organizationId])
  @@index([role])
