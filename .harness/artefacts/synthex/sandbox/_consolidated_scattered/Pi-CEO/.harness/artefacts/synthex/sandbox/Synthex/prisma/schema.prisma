  organizationId String    @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  /// e.g. "2026-03"
  monthYear      String    @map("month_year")
  storyText      String    @map("story_text") @db.Text
  generatedAt    DateTime  @default(now()) @map("generated_at")
  deliveredAt    DateTime? @map("delivered_at")

  // Performance metrics snapshotted at generation time
  totalReach      Int  @default(0) @map("total_reach")
  postsPublished  Int  @default(0) @map("posts_published")
  autonomousPosts Int  @default(0) @map("autonomous_posts")
