/// Written by createEdgeFunctionRunner() in lib/pipelines/runner.ts.
/// One row per pipeline run (not per client — clientsProcessed/clientsFailed are aggregates).
/// Query /api/health/pipelines for latest status per pipeline.
model EdgeFunctionLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Pipeline identifier — matches the functionName passed to createEdgeFunctionRunner()
  functionName     String   @map("function_name")
  /// Unique run ID — UUID generated per run in the factory
  runId            String   @map("run_id") @db.Uuid
  /// Null for aggregate rows (current pattern). May be set for per-client logs in future.
  clientId         String?  @map("client_id") @db.Uuid
  /// Execution outcome: 'success' | 'partial' | 'failed'
  status           String
  durationMs       Int?     @map("duration_ms")
  clientsProcessed Int      @default(0) @map("clients_processed")
  clientsFailed    Int      @default(0) @map("clients_failed")
  /// Per-client error detail when clients fail [{clientId, error, attempt}]
  errorJson        Json?    @map("error_json")
  /// Semantic validation results from validateOutput() — pipeline-specific shape
  /// (see lib/pipelines/metadata-schemas.ts for typed interfaces)
  outputMetadata   Json?    @map("output_metadata")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([functionName, createdAt(sort: Desc)])
  @@map("edge_function_logs")
}

// ============================================================================
// Synthex Authority Score — SYN-513
// ============================================================================

/// Computed E.E.A.T. composite score for a Synthex client organisation.
/// One record per compute run (daily via nightly cron).
/// Latest record per org = current score.
model AuthorityScore {
  id             String   @id @default(cuid())
  /// Maps to client_id in the DB (legacy column name — organisation = client in old schema)
  organizationId String   @map("client_id")

  /// 0–100 composite score
  score          Int

  /// Breakdown per pillar (stored as JSON for flexibility)
  /// Shape: { gbpCompleteness: 0-25, reviewVelocity: 0-20, contentFreshness: 0-20,
  ///          backlinkSignals: 0-15, schemaCoverage: 0-10, socialProof: 0-10 }
  eeAtBreakdown  Json     @map("eeat_breakdown")

  /// Scoring algorithm version — bump when weights change
  signalsVersion String   @default("1.0") @map("signals_version")

  computedAt     DateTime @default(now()) @map("computed_at")

  // Extra analytic columns present in DB (optional, populated by ML pipeline)
  predictedEngagement         Float?   @map("predicted_engagement")
  confidenceScore             Float?   @map("confidence_score")
  crossClientPercentileIndustry Int?   @map("cross_client_percentile_industry")
  featureTags                 String[] @map("feature_tags")

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, computedAt(sort: Desc)])
  @@map("authority_scores")
}

// ── Weekly content calendar — SYN-521 ─────────────────────────────────────────

/// One AI-generated content calendar per organisation per week.
/// Slots are stored as JSONB (CalendarSlot[]) — see lib/calendar/types.ts.
/// status: draft → approved → published
model ContentCalendar {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")

  weekStart DateTime @map("week_start") @db.Date
  weekEnd   DateTime @map("week_end") @db.Date

  /// CalendarSlot[] — see lib/calendar/types.ts
  slots Json

  /// draft | approved | published
  status String @default("draft")

  /// Algorithm version — bump when generation logic changes
  signalsVersion String @default("1.0") @map("signals_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  publishQueueItems PublishQueueItem[]

  @@unique([organizationId, weekStart])
  @@index([organizationId, weekStart(sort: Desc)])
  @@map("content_calendars")
}

// ── Auto-publish queue — SYN-523 ──────────────────────────────────────────────

/// One row per calendar slot awaiting (or having completed) auto-publish.
/// Retry window: 12 attempts × 4-hour intervals = 48 hours before → held.
model PublishQueueItem {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  calendarId     String    @map("calendar_id")
  /// Slot ID from ContentCalendar.slots JSON
  slotId         String    @map("slot_id")
  platform       String
  scheduledAt    DateTime  @map("scheduled_at")
  /// pending | publishing | published | failed | held
  status         String    @default("pending")
  attempts       Int       @default(0)
  nextRetryAt    DateTime? @map("next_retry_at")
  lastError      String?   @map("last_error") @db.Text
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  calendar     ContentCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([organizationId, status])
  @@index([calendarId])
  @@map("publish_queue")
}

// ---------------------------------------------------------------------------
// Predictive Seasonal Signal Engine — SYN-547
// ---------------------------------------------------------------------------

/// Industry-specific, geographically-calibrated market opportunity windows.
/// Populated weekly by the update-seasonal-signals Edge Function.
/// Signals are shared across all organisations — they are industry+state level,
/// not per-client. Clients query via the get_seasonal_signals SQL function.
model SeasonalSignal {
  id               String   @id @default(cuid())
  industrySlug     String   @map("industry_slug")    // e.g. "plumbing-hvac"
  subIndustry      String?  @map("sub_industry")      // nullable, future use
  locationState    String   @map("location_state")   // AU state: VIC|NSW|QLD|WA|SA|TAS|ACT|NT|AU(national)
  signalType       String   @map("signal_type")       // trend_spike|seasonal_peak|local_event|holiday|school_term
  opportunityLabel String   @map("opportunity_label") // human-readable, e.g. "Winter Pipe Season"
  windowStart      DateTime @map("window_start") @db.Date
  windowEnd        DateTime @map("window_end") @db.Date
  confidenceScore  Int      @map("confidence_score") // 0-100
  source           String   // google_trends|abs_data|school_calendar|public_holiday

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dismissals SeasonalSignalDismissal[]

  @@unique([industrySlug, locationState, windowStart, source], name: "seasonal_signal_dedup")
  @@index([industrySlug, locationState])
  @@index([windowStart])
  @@index([confidenceScore])
  @@map("seasonal_signals")
}

/// Per-org dismissal of a seasonal market opportunity signal — SYN-549
/// Once dismissed, the signal is not re-inserted into that org's calendar.
model SeasonalSignalDismissal {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  signalId       String         @map("signal_id")
  dismissedAt    DateTime       @default(now()) @map("dismissed_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signal       SeasonalSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@unique([organizationId, signalId])
  @@index([organizationId])
  @@map("seasonal_signal_dismissals")
}

