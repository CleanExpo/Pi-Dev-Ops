  teamMemberId   String     @map("team_member_id")
  organizationId String     @map("organization_id")
  pagePath       String     @map("page_path")
  viewedAt       DateTime   @default(now()) @map("viewed_at")

  teamMember     TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@index([teamMemberId])
  @@index([organizationId])
  @@index([viewedAt])
  @@index([organizationId, pagePath])
  @@map("team_member_page_views")
}

/// Weekly marketing health score for each client org — SYN-611
/// Separate from UserHealthScore (gamification) — this tracks marketing health over time.
/// Computed every Monday 05:00 AEDT by the compute-health-scores Edge Function.
model ClientHealthScore {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")

  /// Monday of the week this score covers (date only, UTC)
  weekStart      DateTime @map("week_start") @db.Date

  /// Composite 0-100 score (weighted average of all dimensions)
  overallScore   Int      @map("overall_score")

  /// Per-dimension breakdown — JSONB shape:
  /// { content_consistency: { score, raw_value, description },
  ///   engagement_trajectory: { score, raw_value, description },
  ///   review_responsiveness: { score, raw_value, description },
  ///   authority_momentum: { score, raw_value, description },
  ///   advisor_engagement: { score, raw_value, description },
  ///   platform_usage: { score, raw_value, description } }
  dimensions     Json

  /// Change from previous week's overallScore (positive = improved)
  scoreDelta     Int      @default(0) @map("score_delta")

  /// healthy(75-100) | watch(50-74) | at_risk(25-49) | critical(0-24)
  /// null = insufficient_data (< 2 non-null dimensions)
  riskLevel      String?  @map("risk_level")

  /// Shadow dimensions logged but NOT included in composite score while JOURNEY_DIMENSION_ACTIVE = false.
  /// Shape: { journey_engagement: { score, raw_value, description } | null }
  /// SYN-679 — 4-week validation protocol before promotion to active dimension
  shadowDimensions Json?  @map("shadow_dimensions")

  createdAt      DateTime @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, weekStart], name: "client_health_score_org_week")
  @@index([organizationId])
  @@index([weekStart])
  @@index([riskLevel])
  @@map("client_health_scores")
}

/// Config for Health Score dimension weights + feature flags — single row — SYN-611/613
model HealthScoreConfig {
  id      String   @id @default(cuid())
  /// JSONB: { content_consistency: 0.25, engagement_trajectory: 0.20,
  ///          review_responsiveness: 0.15, authority_momentum: 0.15,
  ///          advisor_engagement: 0.15, platform_usage: 0.10 }
  weights Json
  /// When true, Health Score widget appears on client-facing dashboard.
  /// Phill flips this after 4-week internal validation period. Default: false.
  clientVisible Boolean  @default(false) @map("client_visible")
  updatedAt     DateTime @updatedAt @map("updated_at")
  @@map("health_score_config")
}

/// Client interaction events — dual-written to GA4 + Supabase for Health Score computation — SYN-612
/// Privacy: no PII in event_data; clientId is internal UUID, not email.
model ClientEngagementEvent {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id") // Organization.id

  /// Event types: dashboard_visit | calendar_post_viewed | calendar_post_approved |
  /// calendar_post_dismissed | digest_email_opened | advisor_brief_viewed |
  /// review_response_started | review_response_published | authority_hub_viewed | settings_changed
  eventType String   @map("event_type")

  /// Structured metadata — no PII
  eventData Json?    @map("event_data")

  pagePath  String?  @map("page_path")

  /// Random UUID per browser session — not a tracking cookie
  sessionId String   @map("session_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId, eventType, createdAt])
  @@index([clientId, createdAt])
  @@map("client_engagement_events")
}

// ============================================================================
// Client Retention Engine — SYN-614 (SYN-615/616/617/620)
// ============================================================================

/// Per-dimension intervention configuration + staged activation dates — SYN-615/620
/// One row per dimension (6 rows total). `enabled` false = observation mode.
model InterventionConfig {
  id         String  @id @default(cuid())
  dimension  String  @unique // content_consistency | engagement_trajectory | etc.
  tier1Threshold Int  @default(15) @map("tier_1_threshold") // points decline → Advisor Priority
  tier2Threshold Int  @default(25) @map("tier_2_threshold") // points decline → Value Proof Email
  tier3Threshold Int  @default(35) @map("tier_3_threshold") // points decline → Founder Outreach
  enabled    Boolean @default(false) // false = observation mode for this dimension

  /// Staged activation dates (SYN-620) — null = not yet active / still in observation
  tier3ActiveFrom DateTime? @map("tier_3_active_from") // Tier 3 activates immediately at deploy
  tier2ActiveFrom DateTime? @map("tier_2_active_from") // Tier 2 activates at 14 days
  tier1ActiveFrom DateTime? @map("tier_1_active_from") // Tier 1 activates at 30 days

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("intervention_config")
}

/// Intervention event log — all interventions logged, dispatched or not — SYN-615
/// observation_mode = true → logged but NOT sent (calibration period)
model HealthIntervention {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  dimension       String   // which dimension triggered this
  currentScore    Int      @map("current_score")
  baselineScore   Int      @map("baseline_score") // 30-day rolling average
  declineMagnitude Int     @map("decline_magnitude") // currentScore - baselineScore (negative)
  interventionTier Int     @map("intervention_tier") // 1 | 2 | 3
  interventionType String  @map("intervention_type") // advisor_priority | value_proof_email | founder_outreach
  channel         String   @default("in_app") // in_app | email | founder_queue
  templateId      String?  @map("template_id") // FK to intervention_templates.id
  observationMode Boolean  @default(true) @map("observation_mode")
  wouldHaveSentAt DateTime @map("would_have_sent_at")
  actuallySentAt  DateTime? @map("actually_sent_at") // null = still in observation or not yet sent

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([dimension, createdAt])
  @@index([observationMode])
  @@map("health_interventions")
}

/// Template library for all three intervention tiers — SYN-616
/// Templates are rendered with merge fields at dispatch time.
model InterventionTemplate {
  id              String  @id @default(cuid())
  tier            Int     // 1 | 2 | 3
  dimension       String? // null = applies to all dimensions
  channel         String  // email | in_app | founder_queue
  subjectTemplate String? @map("subject_template") @db.Text
  bodyTemplate    String  @map("body_template") @db.Text
  heroMetricSource String? @map("hero_metric_source") // dollar_attribution | reach | reviews_handled
  active          Boolean @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tier, dimension, channel], name: "intervention_template_tier_dim_ch")
  @@map("intervention_templates")
}

/// Tier 3 founder outreach queue — SYN-616
/// Phill reviews daily and sends personalised emails manually.
model FounderOutreachQueue {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  flaggedAt       DateTime @default(now()) @map("flagged_at")
  healthScoreTrend Json    @map("health_score_trend") // last 4 weekly scores
  talkingPoints   String   @map("talking_points") @db.Text // AI-generated talking points
  resolvedAt      DateTime? @map("resolved_at")
  resolvedNote    String?   @map("resolved_note") @db.Text

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([flaggedAt])
  @@index([resolvedAt])
  @@map("founder_outreach_queue")
}

// ─────────────────────────────────────────────────────────────────────────────
// Content Learning Loop — SYN-631
// ─────────────────────────────────────────────────────────────────────────────

/// Per-org content intelligence profile — SYN-631
/// Computed weekly by compute-content-profiles cron.
/// Blended with IndustryBaseline weighted by confidenceLevel.
/// confidenceLevel = min(1.0, postCount / 60) — 60 published posts = full trust.
model ContentPerformanceProfile {
  id             String  @id @default(cuid())
  organizationId String  @unique @map("organization_id")

  /// Total published posts analysed to build this profile
  postCount       Int   @default(0) @map("post_count")
  /// 0.0–1.0. Weight applied to org-specific signals vs industry baseline
  confidenceLevel Float @default(0.0) @map("confidence_level")

  /// Top content topics ranked by avg engagement rate (JSON array of TopicScore)
  topTopics           Json @default("[]") @map("top_topics")
  /// Best posting times per day-of-week (JSON map: "MON" → ["09:00","17:00"])
  optimalTimes        Json @default("{}") @map("optimal_times")
  /// Hashtags sorted by avg reach contribution (JSON array of strings)
  winningHashtags     Json @default("[]") @map("winning_hashtags")
  /// Per-format avg engagement rate (JSON map: "video"|"image"|"carousel"|"text" → Float)
  contentFormatScores Json @default("{}") @map("content_format_scores")

  industryBaselineId String? @map("industry_baseline_id")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  industryBaseline IndustryBaseline? @relation(fields: [industryBaselineId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([updatedAt])
  @@map("content_performance_profiles")
}

/// Industry-level content baseline — SYN-631
/// Seeded and updated by compute-content-profiles cron across all orgs per industry.
/// Acts as a prior for orgs with < 60 published posts.
model IndustryBaseline {
  id         String @id @default(cuid())
  /// Matches Organization.industry (e.g. "plumbing-hvac", "real-estate", "general")
  industry   String @unique

  /// Number of org profiles contributing to this baseline
  sampleSize Int @default(0) @map("sample_size")

  /// Aggregated top topics across all orgs in this industry
  topTopics           Json @default("[]") @map("top_topics")
  /// Aggregated optimal posting times across all orgs in this industry
  optimalTimes        Json @default("{}") @map("optimal_times")
  /// Aggregated winning hashtags across all orgs in this industry
  winningHashtags     Json @default("[]") @map("winning_hashtags")
  /// Aggregated content format scores across all orgs in this industry
  contentFormatScores Json @default("{}") @map("content_format_scores")

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  profiles ContentPerformanceProfile[]

  @@index([industry])
  @@map("industry_baselines")
}

// ─────────────────────────────────────────────────────────────────────────────
// Content improvement tracking — SYN-632
// ─────────────────────────────────────────────────────────────────────────────

/// Weekly comparison of intelligence-informed vs baseline calendar posts — SYN-632
/// Populated by compute-content-profiles cron after each weekly run.
/// Enables tracking of whether content intelligence improves engagement over time.
model ContentImprovementTracking {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  weekStart      DateTime @map("week_start") @db.Date

  /// Avg engagement rate for posts generated with content intelligence applied
  informedAvgEngagement  Float? @map("informed_avg_engagement")
  /// Avg engagement rate for posts generated without content intelligence
  baselineAvgEngagement  Float? @map("baseline_avg_engagement")
  /// (informedAvgEngagement - baselineAvgEngagement) / baselineAvgEngagement
  /// null when baseline is 0 or comparison is not yet possible
  improvementRate        Float? @map("improvement_rate")

  /// Intelligence signals that were active this week (JSON array of signal descriptions)
  intelligenceSignalsUsed Json @default("[]") @map("intelligence_signals_used")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, weekStart], name: "content_improvement_dedup")
  @@index([organizationId, weekStart(sort: Desc)])
  @@map("content_improvement_tracking")
}

// ============================================================================
// Lead ground-truth — SYN-794
// Single-table lead capture with stage transitions. Replaces separate
// Enquiry/Conversion tables. `rawPayload` preserves source-of-truth evidence
// for later attribution audit.
// ============================================================================

enum LeadStage {
  enquiry
  qualified
  converted
}

enum LeadContactMethod {
  form_submission
  phone_call
  direction_request
  booking
}

model Lead {
  id                    String            @id @default(cuid())
  organizationId        String            @map("organization_id")
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage                 LeadStage         @default(enquiry)
  contactMethod         LeadContactMethod @map("contact_method")
  source                String?
  medium                String?
  campaign              String?
  occurredAt            DateTime          @map("occurred_at")
  capturedFrom          String            @map("captured_from")
  rawPayload            Json              @map("raw_payload")
  revenueEstimateAud    Decimal?          @map("revenue_estimate_aud") @db.Decimal(12, 2)
  verifiedRevenueAud    Decimal?          @map("verified_revenue_aud") @db.Decimal(12, 2)
  verifiedAt            DateTime?         @map("verified_at")
  verifiedByUserId      String?           @map("verified_by_user_id")
  attributionWindowDays Int               @default(30) @map("attribution_window_days")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@index([organizationId, occurredAt])
  @@index([organizationId, stage])
  @@map("leads")
}

// --- Restored 2026-05-01 - Phase 1 validation false-negative ---
// These 6 models are referenced via dynamic Prisma accessors
// (prisma as Foo) in 3 active routes: /api/competitors/track,
// /api/reports/scheduled, /api/reports/templates. Audit grep
// missed them. Restored here; the remaining 7 truly-drift tables
// stay dropped. See SYN-855 follow-up.

model ScheduledReport {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  organizationId String?   @map("organization_id")
  name           String
  description    String?
  templateId     String?   @map("template_id") // Reference to ReportTemplate
  reportType     String    @map("report_type") // overview, engagement, content, audience, campaigns, growth, custom
  frequency      String // daily, weekly, biweekly, monthly, quarterly
  schedule       Json // { dayOfWeek?, dayOfMonth?, hour, minute, timezone }
  format         String    @default("pdf") // pdf, csv, json
  dateRangeType  String    @default("last_period") @map("date_range_type") // last_period, custom, rolling_7d, rolling_30d
  filters        Json? // Platform, campaign, and other filters
  metrics        String[] // Selected metrics to include
  recipients     String[] // Email addresses
  webhookUrl     String?   @map("webhook_url") // Optional webhook delivery
  isActive       Boolean   @default(true) @map("is_active")
  lastRunAt      DateTime? @map("last_run_at")
  lastRunStatus  String?   @map("last_run_status") // success, failed, skipped
  lastReportId   String?   @map("last_report_id") // ID of last generated report
  nextRunAt      DateTime? @map("next_run_at")
  runCount       Int       @default(0) @map("run_count")
  failureCount   Int       @default(0) @map("failure_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  template ReportTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([isActive, nextRunAt])
  @@index([organizationId])
  @@map("scheduled_reports")
}

model ReportTemplate {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id") // null = system template
  organizationId String?  @map("organization_id")
  name           String
  description    String?
  category       String // performance, engagement, growth, content, custom
  reportType     String   @map("report_type") // overview, engagement, content, audience, campaigns, growth, custom
  metrics        String[] // Default metrics
  dimensions     String[] // Grouping dimensions
  filters        Json? // Default filters
  visualizations Json? // Chart configurations
  layout         Json? // Report layout settings
  branding       Json? // Custom branding (logo, colors)
  isSystem       Boolean  @default(false) @map("is_system") // System-provided template
  isPublic       Boolean  @default(false) @map("is_public") // Shared with organization
  usageCount     Int      @default(0) @map("usage_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  scheduledReports ScheduledReport[]

  @@index([userId])
  @@index([organizationId])
  @@index([isSystem])
  @@index([category])
  @@map("report_templates")
}

model ReportDelivery {
  id                String    @id @default(cuid())
  reportId          String    @map("report_id")
  scheduledReportId String?   @map("scheduled_report_id")
  deliveryType      String    @map("delivery_type") // email, webhook, download
  recipient         String // Email address or webhook URL
  status            String // pending, sent, delivered, failed, bounced
  sentAt            DateTime? @map("sent_at")
  deliveredAt       DateTime? @map("delivered_at")
  failedAt          DateTime? @map("failed_at")
  failureReason     String?   @map("failure_reason")
  retryCount        Int       @default(0) @map("retry_count")
  metadata          Json? // Provider response, message ID, etc.
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([reportId])
  @@index([scheduledReportId])
  @@index([status])
  @@map("report_deliveries")
}

model CompetitorSnapshot {
  id           String @id @default(cuid())
  competitorId String @map("competitor_id")

  // Platform metrics
  platform String // 'twitter', 'instagram', etc. or 'all'

  // Follower metrics
  followersCount Int? @map("followers_count")
  followingCount Int? @map("following_count")
  followerGrowth Int? @map("follower_growth") // Change since last snapshot

  // Engagement metrics
  totalPosts     Int?   @map("total_posts")
  avgLikes       Float? @map("avg_likes")
  avgComments    Float? @map("avg_comments")
  avgShares      Float? @map("avg_shares")
  engagementRate Float? @map("engagement_rate")
  postFrequency  Float? @map("post_frequency") // Posts per day

  // Content metrics
  topHashtags  String[] @map("top_hashtags")
  contentTypes Json?    @map("content_types") // Distribution of content types
  postingTimes Json?    @map("posting_times") // Typical posting times

  // Calculated scores
  performanceScore Float? @map("performance_score") // 0-100 overall performance
  growthScore      Float? @map("growth_score") // 0-100 growth trajectory
  engagementScore  Float? @map("engagement_score") // 0-100 engagement health

  // Metadata
  snapshotAt DateTime @default(now()) @map("snapshot_at")
  dataSource String   @default("api") @map("data_source") // 'api', 'scraper', 'manual'

  // Relations
  competitor TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([competitorId, snapshotAt])
  @@index([platform])
  @@index([snapshotAt])
  @@map("competitor_snapshots")
}

model CompetitorPost {
  id           String @id @default(cuid())
  competitorId String @map("competitor_id")

  // Post details
  platform   String
  externalId String?  @map("external_id") // Platform-specific post ID
  postUrl    String?  @map("post_url")
  content    String?  @db.Text
  mediaUrls  String[] @map("media_urls")
  mediaType  String?  @map("media_type") // 'image', 'video', 'carousel', 'text'

  // Engagement metrics
  likes          Int    @default(0)
  comments       Int    @default(0)
  shares         Int    @default(0)
  views          Int?
  saves          Int?
  engagementRate Float? @map("engagement_rate")

  // Content analysis
  sentiment String? // 'positive', 'neutral', 'negative'
  hashtags  String[]
  mentions  String[]
  topics    String[]

  // Performance
  isTopPerforming       Boolean @default(false) @map("is_top_performing")
  performancePercentile Float?  @map("performance_percentile") // Where this post ranks (0-100)

  // Timestamps
  postedAt  DateTime? @map("posted_at")
  trackedAt DateTime  @default(now()) @map("tracked_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  competitor TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, platform, externalId])
  @@index([competitorId])
  @@index([platform])
  @@index([postedAt])
  @@index([isTopPerforming])
  @@map("competitor_posts")
}

model CompetitorAlert {
  id           String @id @default(cuid())
  userId       String @map("user_id")
  competitorId String @map("competitor_id")

  // Alert details
  alertType   String @map("alert_type") // 'viral_post', 'follower_spike', 'new_campaign', 'strategy_change', 'milestone'
  severity    String @default("info") // 'info', 'warning', 'important'
  title       String
  description String @db.Text

  // Related data
  relatedPostId String? @map("related_post_id")
  metrics       Json? // Relevant metrics that triggered alert

  // Status
  isRead      Boolean @default(false) @map("is_read")
  isDismissed Boolean @default(false) @map("is_dismissed")
  actionTaken String? @map("action_taken") @db.Text

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  // Relations
  competitor TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([competitorId])
  @@index([isRead])
  @@index([createdAt])
  @@map("competitor_alerts")
}

// ============================================================================
// HERMES — proactive intelligence layer above Synthex (HER-1a / SYN-909)
// Pilot: RestoreAssist, text-only LinkedIn + GBP, 24h cron, log-only voice gate.
// All four tables RLS-scoped to organizationId. Service role bypasses (cron writes).
// ============================================================================

/// HermesConfig — per-org HERMES configuration. One record per org that runs HERMES.
/// Mirror of AutopilotConfig shape but scoped to HERMES's discovery/draft pipeline.
model HermesConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  enabled    Boolean @default(false) // Pilot starts disabled. Flipped manually to begin H-1.
  brandSlug  String  @map("brand_slug") // BrandSlug enum value (e.g. 'ra')
  dailyQuota Int     @default(5) @map("daily_quota") // Max drafts per day per org
  voiceFloor Int     @default(70) @map("voice_floor") // Score threshold for voice gate (H-1: 70, H-2: 80)

  lastRunAt DateTime? @map("last_run_at")
  nextRunAt DateTime? @map("next_run_at")

  // H-1 use: stores traffic baseline for >30% drop detection.
  // Shape: { trafficBaseline: { date: string, value: number }[] }
  // MUST be manually seeded before first discovery sweep — see lib/hermes/discovery/README.md.
  metadata Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("hermes_config")
}

/// HermesDiscoverySignal — a single signal captured by the discovery sweep.
/// Sources: GSC traffic, GBP insights, LinkedIn impressions, manual.
/// Severity 'urgent' triggers Telegram escalation; 'routine' is logged only.
model HermesDiscoverySignal {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  signalType String   @map("signal_type") // 'traffic_drop' | 'competitor' | 'regulatory' | 'gap'
  source     String                       // URL or data source identifier
  payload    Json                         // Raw signal data
  severity   String   @default("routine") // 'routine' | 'urgent'

  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, signalType])
  @@map("hermes_discovery_signal")
}

/// HermesGapCandidate — a content gap identified by the gap engine.
/// One signal can seed multiple gaps. HER-1d picks top dailyQuota for drafting.
model HermesGapCandidate {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  topic     String
  rationale String                          // ≤ 280 chars — why this is a gap
  signalIds String[] @map("signal_ids")     // FKs into HermesDiscoverySignal.id (denormalised)
  priority  Int      @default(0)            // 0..100, derived from signal urgency
  status    String   @default("open")       // 'open' | 'drafted' | 'rejected'

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  proposals HermesProposal[]

  @@index([organizationId, status, priority(sort: Desc)])
  @@map("hermes_gap_candidate")
}

/// HermesProposal — a draft generated for a gap candidate.
/// Lifecycle: pending → queued (Calendar write succeeded) | rejected (hard-fail).
/// metadata JSON keys (NOT separate columns):
///   readabilityWarning: boolean — true when FK grade is in warn band (6–8)
///   readabilityGrade:   number  — actual FK grade score
model HermesProposal {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  gapCandidateId String?             @map("gap_candidate_id")
  gapCandidate   HermesGapCandidate? @relation(fields: [gapCandidateId], references: [id], onDelete: SetNull)

  postId String? @unique @map("post_id")
  post   Post?   @relation("HermesProposalPost", fields: [postId], references: [id], onDelete: SetNull)

  content           String
  voiceScore        Int?     @map("voice_score")
  voiceGateDecision String?  @map("voice_gate_decision") // 'pass' | 'warn' | 'fail'
  voiceFailedRules  String[] @map("voice_failed_rules")
  metadata          Json     @default("{}")

  status String @default("pending") // 'pending' | 'queued' | 'rejected'

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("hermes_proposal")
}

