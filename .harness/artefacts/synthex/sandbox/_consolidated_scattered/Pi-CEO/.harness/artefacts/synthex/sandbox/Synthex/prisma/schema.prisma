  @@unique([organizationId, gbpReviewId])
  @@index([organizationId])
  @@index([locationId])
  @@index([rating])
  @@index([reviewTime])
  @@index([organizationId, status, reviewTime(sort: Desc)])
  @@index([organizationId, displayOnWidget, isFeatured])
