// ==========================================
// Adaptive Intelligence Engine
// BO + Prophet + BayesNF
// ==========================================

// ─── Bayesian Optimisation (Engine 1) ──────────────────────────

model BOSpace {
  id                String              @id @default(cuid())
  orgId             String              @map("org_id")
  userId            String              @map("user_id")
  surface           String // BOSurface enum value
  name              String? // Human-readable label
  parameters        Json // Record<string, { min, max }>
  acquisitionFn     String              @default("ei") @map("acquisition_fn")
  constraints       Json? // { sumEquals?: number }
  status            String              @default("active")
  bestParameters    Json?               @map("best_parameters")
  bestTarget        Float?              @map("best_target")
  totalObservations Int                 @default(0) @map("total_observations")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  observations      BOObservation[]
  runs              BOOptimisationRun[]
  user              User                @relation(fields: [userId], references: [id])

  @@unique([orgId, surface])
  @@index([orgId])
  @@index([userId])
  @@map("bo_spaces")
}

model BOObservation {
  id         String   @id @default(cuid())
  spaceId    String   @map("space_id")
  parameters Json // Record<string, number>
  target     Float // Observed outcome
  metadata   Json? // Source context
  recordedAt DateTime @default(now()) @map("recorded_at")
  space      BOSpace  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([recordedAt])
  @@map("bo_observations")
}

model BOOptimisationRun {
  id               String    @id @default(cuid())
  spaceId          String    @map("space_id")
  orgId            String    @map("org_id")
  userId           String    @map("user_id")
