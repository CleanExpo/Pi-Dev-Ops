  competitorPosition Float?    @map("competitor_position")
  impressions        Int?
  displacementScore  Float?    @map("displacement_score")
  snapshotDate       DateTime  @map("snapshot_date") @db.Date
  createdAt          DateTime  @default(now()) @map("created_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  competitor   TrackedCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, keyword, snapshotDate])
  @@index([organizationId, snapshotDate])
  @@index([competitorId])
  @@map("competitor_keyword_gaps")
}


// ==========================================
// AI Project Manager — Per-Client AI PM (Business plan)
// Conversational interface that learns each client's business
// ==========================================

model AIConversation {
  id     String @id @default(cuid())
  userId String @map("user_id")
  title  String @default("New Conversation")
  status String @default("active") // 'active', 'archived', 'deleted'

  // Context snapshot at conversation start (compressed user data for continuity)
  contextSnapshot Json? @map("context_snapshot")

  // Stats
  messageCount  Int       @default(0) @map("message_count")
  lastMessageAt DateTime? @map("last_message_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([status])
  @@map("ai_conversations")
}

model AIMessage {
  id             String @id @default(cuid())
  conversationId String @map("conversation_id")

  // Message content
  role    String // 'user', 'assistant', 'system'
  content String @db.Text

  // AI metadata
  model      String? // AI model used (e.g. 'claude-sonnet-4-20250514')
  tokensUsed Int?    @map("tokens_used") // Total tokens (prompt + completion)
  latencyMs  Int?    @map("latency_ms") // Response time in milliseconds

  // Structured data extracted from AI responses
  actionItems Json? @map("action_items") // [{ title, description, priority, completed }]
  suggestions Json? // [{ type, title, description, actionUrl }]

  // User feedback on AI response
  rating   Int? // 1-5 thumbs rating
  feedback String? // Free-text feedback

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([role])
  @@map("ai_messages")
}

// ==========================================
// AI Weekly Digest — Proactive value delivery
// Monday morning summaries generated by AI PM
// ==========================================

model AIWeeklyDigest {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Time window
  weekStart DateTime @map("week_start") @db.Date
  weekEnd   DateTime @map("week_end") @db.Date

  // AI-generated content
  summary       String @db.Text // Executive summary paragraph
  highlights    Json // [{ metric, value, change, trend }]
  actionItems   Json   @map("action_items") // [{ title, description, priority, actionUrl }]
  opportunities Json // [{ title, description, potentialImpact }]

  // Delivery tracking
  emailSent   Boolean   @default(false) @map("email_sent")
  emailSentAt DateTime? @map("email_sent_at")
  opened      Boolean   @default(false)
  openedAt    DateTime? @map("opened_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_weekly_digests")
}

// ==========================================
// Health Scoring — Churn prediction & re-engagement
// Weighted composite score: login + content + features + engagement + growth
// ==========================================

model UserHealthScore {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // Composite score (0-100)
  score     Int    @default(50)
  trend     String @default("stable") // 'improving', 'stable', 'declining', 'critical'
  riskLevel String @default("medium") @map("risk_level") // 'healthy', 'medium', 'high', 'critical'

  // Component scores (0-100 each)
  loginScore      Int @default(50) @map("login_score") // Login frequency (25% weight)
  contentScore    Int @default(50) @map("content_score") // Content creation activity (25% weight)
  featureScore    Int @default(50) @map("feature_score") // Feature breadth usage (20% weight)
  engagementScore Int @default(50) @map("engagement_score") // Platform engagement (20% weight)
  growthScore     Int @default(50) @map("growth_score") // Growth trajectory (10% weight)

  // Raw metrics used for scoring
  daysActive       Int @default(0) @map("days_active") // Days active in last 30
  featuresUsed     Int @default(0) @map("features_used") // Unique features used in last 30 days
  contentCreated   Int @default(0) @map("content_created") // Content pieces created in last 30 days
  lastLoginDaysAgo Int @default(0) @map("last_login_days_ago") // Days since last login

  // Alert tracking
  alertSent     Boolean   @default(false) @map("alert_sent")
  alertSentAt   DateTime? @map("alert_sent_at")
  lastAlertType String?   @map("last_alert_type") // 'email', 'notification', 'both'

  calculatedAt DateTime @default(now()) @map("calculated_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([score])
  @@index([riskLevel])
  @@map("user_health_scores")
}

// ==========================================
// Gamification — DB-persisted streaks & achievements
// Replaces localStorage-only StreakCounter
// ==========================================

model UserStreak {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // Streak data
  currentStreak  Int       @default(0) @map("current_streak")
  longestStreak  Int       @default(0) @map("longest_streak")
  totalDays      Int       @default(0) @map("total_days")
  lastActiveDate DateTime? @map("last_active_date") @db.Date

  // Leveling (based on total activity)
  level  Int @default(1)
  points Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model UserAchievement {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Achievement identity
  achievementId String @map("achievement_id") // Unique key from achievements catalog (e.g. 'first_post', '7_day_streak')
  name          String
  description   String
  icon          String // Emoji or icon name
  category      String // 'content', 'engagement', 'consistency', 'exploration', 'social'
  rarity        String @default("common") // 'common', 'uncommon', 'rare', 'epic', 'legendary'

  // Progress tracking
  progress      Int       @default(100) // 0-100 (100 = unlocked)
  unlockedAt    DateTime? @map("unlocked_at")
  pointsAwarded Int       @default(0) @map("points_awarded")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, category])
  @@index([unlockedAt])
  @@map("user_achievements")
}

// ==========================================
// Referral System — Viral growth loops
// Format: SYN-XXXX codes
// ==========================================

model Referral {
  id           String  @id @default(cuid())
  referrerId   String  @map("referrer_id")
  refereeId    String? @unique @map("referee_id") // Set when referee signs up (one-to-one)
  refereeEmail String  @map("referee_email") // Email invited

  // Referral code
  code String @unique // Format: SYN-XXXX

  // Status tracking
  status String @default("sent") // 'sent', 'clicked', 'signed_up', 'converted', 'expired'

  // Reward tracking
  referrerRewarded Boolean @default(false) @map("referrer_rewarded")
  refereeRewarded  Boolean @default(false) @map("referee_rewarded")
  rewardType       String? @map("reward_type") // 'credits', 'discount', 'feature_unlock'
  rewardAmount     Int?    @map("reward_amount") // e.g., 500 for 500 AI credits

  // Metadata
  clickedAt   DateTime? @map("clicked_at")
  signedUpAt  DateTime? @map("signed_up_at")
  convertedAt DateTime? @map("converted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  referrer User  @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User? @relation("RefereeReferral", fields: [refereeId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([refereeEmail])
  @@index([status])
  @@map("referrals")
}

// ==========================================
// Loyalty Tiers — Long-term retention & rewards
// Bronze → Silver → Gold → Platinum
// ==========================================

model UserLoyaltyTier {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // Tier progression
  tier           String @default("bronze") // 'bronze', 'silver', 'gold', 'platinum'
  points         Int    @default(0) // Current period points
  lifetimePoints Int    @default(0) @map("lifetime_points") // All-time points
  monthsActive   Int    @default(0) @map("months_active") // Consecutive months subscribed

  // Tier benefits
  bonusAiCredits  Int     @default(0) @map("bonus_ai_credits") // Extra AI posts per month
  discountPercent Float   @default(0) @map("discount_percent") // Subscription discount %
  prioritySupport Boolean @default(false) @map("priority_support")

  // Tracking
  lastTierChange DateTime? @map("last_tier_change")
  nextTierAt     Int?      @map("next_tier_at") // Points needed for next tier

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@map("user_loyalty_tiers")
}

// ==========================================
// Feedback & NPS Surveys — Voice of customer
// Triggered at key moments (onboarding, milestones, monthly)
// ==========================================

model FeedbackSurvey {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Survey type
  type         String // 'nps', 'csat', 'feature_request', 'churn_exit'
  triggerEvent String? @map("trigger_event") // What triggered this survey (e.g. 'day_7', 'first_publish', 'cancel')

  // Response data
  score   Int? // NPS: 0-10, CSAT: 1-5
  comment String?  @db.Text
  tags    String[] // Categorized feedback tags

  // Follow-up
  followUpSent Boolean   @default(false) @map("follow_up_sent")
  followUpAt   DateTime? @map("follow_up_at")
  resolved     Boolean   @default(false)
  resolvedAt   DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([score])
  @@index([createdAt])
  @@map("feedback_surveys")
}

// ==========================================
// GEO / E-E-A-T / Paper Banana Integration
// Author profiles, SEO audits, GEO analysis,
// research reports, visual assets, local case studies
// ==========================================

model AuthorProfile {
  id     Int    @id @default(autoincrement())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  name        String
  slug        String  @unique
  bio         String  @db.Text
  credentials Json? // [{type, title, institution, year}]
  socialLinks Json?   @map("social_links") // {linkedin, twitter, youtube, wikipedia, scholar}
  avatarUrl   String? @map("avatar_url")

  // Entity linking (Schema.org sameAs)
  sameAsUrls     String[] @map("same_as_urls")
  expertiseAreas String[] @map("expertise_areas")

  // Verification
  verifiedAt DateTime? @map("verified_at")
  eeatScore  Float?    @map("eeat_score") // Cached E-E-A-T score for this author

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  articles    ArticleAuthor[]
  geoAnalyses GEOAnalysis[]

  @@index([userId])
  @@map("author_profiles")
}

model SEOAudit {
  id     Int    @id @default(autoincrement())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Audit target
  url       String
  auditType String @map("audit_type") // 'full', 'page', 'geo', 'eeat'

  // Scores
  overallScore   Float @map("overall_score")
  eeatScore      Json? @map("eeat_score") // {experience, expertise, authority, trust, overall}
  geoScore       Json? @map("geo_score") // {citability, structure, multiModal, authority, technical, overall}
  technicalScore Json? @map("technical_score") // {performance, accessibility, seo, bestPractices}

  // Results
  recommendations Json // [{priority, category, description, impact}]
  rawData         Json? @map("raw_data") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt])
  @@index([auditType])
  @@map("seo_audits")
}

model ScheduledAuditTarget {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url            String
  name           String // Friendly name like "Main Site" or "Blog"
  frequency      String // "daily", "weekly", "monthly"
  alertThreshold Int     @default(10) @map("alert_threshold") // Score drop percentage to trigger alert
  enabled        Boolean @default(true)

  lastRunAt DateTime? @map("last_run_at")
  lastScore Float?    @map("last_score")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([enabled, frequency])
  @@map("scheduled_audit_targets")
}

model GEOAnalysis {
  id     Int    @id @default(autoincrement())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content reference
  contentId   String?        @map("content_id") // Reference to Post or custom content
  authorId    Int?           @map("author_id")
  author      AuthorProfile? @relation(fields: [authorId], references: [id])
  contentUrl  String?        @map("content_url")
  contentText String         @map("content_text") @db.Text
  platform    String // 'google_aio', 'chatgpt', 'perplexity', 'all'

  // Scores (0-100)
  overallScore         Float  @map("overall_score")
  citabilityScore      Float  @map("citability_score") // Passage-level citability (25% weight)
  structureScore       Float  @map("structure_score") // Heading hierarchy, lists, tables (20% weight)
  multiModalScore      Float  @map("multi_modal_score") // Images, video, interactive (15% weight)
  authorityScore       Float  @map("authority_score") // E-E-A-T + brand signals (20% weight)
  technicalScore       Float  @map("technical_score") // SSR, AI crawlers, llms.txt (20% weight)
  entityCoherenceScore Float? @map("entity_coherence_score") // Entity density + coherence (standalone metric)

  // Detailed findings
  citablePassages Json  @map("citable_passages") // [{text, wordCount, score, startIndex}]
  recommendations Json // [{priority, action, impact, effort}]
  schemaIssues    Json? @map("schema_issues") // Missing/invalid structured data

  // Relations
  entityAnalysis EntityAnalysis?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([platform])
  @@index([overallScore])
  @@map("geo_analyses")
}

model EntityAnalysis {
  id            Int         @id @default(autoincrement())
  geoAnalysisId Int         @unique @map("geo_analysis_id")
  geoAnalysis   GEOAnalysis @relation(fields: [geoAnalysisId], references: [id], onDelete: Cascade)
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Entity extraction results
  entityCount       Int   @map("entity_count")
  uniqueEntityCount Int   @map("unique_entity_count")
  properNounDensity Float @map("proper_noun_density")
  coherenceScore    Float @map("coherence_score")
  entities          Json // EntityMention[] — full extraction result
  coherenceIssues   Json  @map("coherence_issues") // string[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([coherenceScore])
  @@map("entity_analyses")
}

model GEOResearchReport {
  id     Int    @id @default(autoincrement())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Report identity
  title    String
  slug     String @unique
  status   String @default("draft") // 'draft', 'review', 'published'
  sasScore Float? @map("sas_score") // Synthex Authority Score (0-10)

  // Content sections
  executiveSummary String? @map("executive_summary") @db.Text
  methodology      String? @db.Text
  findings         Json? // [{finding, statistic, source, citationUrl}]
  recommendations  Json? // [{step, description, priority}]
  fullContent      String? @map("full_content") @db.Text

  // Data & citations
  dataSources Json?   @map("data_sources") // [{name, url, type, trustLevel}]
  citations   Json? // [{text, source, url, accessedAt}]
  datasetUrl  String? @map("dataset_url") // CSV/JSON download link

  // SEO metadata
  schemaMarkup    Json?   @map("schema_markup") // Full JSON-LD
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  // Timestamps
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Organisation (multi-tenant)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation("OrganizationGEOReports", fields: [organizationId], references: [id], onDelete: SetNull)

  // Relations
  visuals VisualAsset[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("geo_research_reports")
}

model VisualAsset {
  id     Int    @id @default(autoincrement())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Report link (optional)
  reportId Int?               @map("report_id")
  report   GEOResearchReport? @relation(fields: [reportId], references: [id])

  // Paper Banana metadata
  type         String // 'diagram', 'plot', 'infographic', 'before_after'
  prompt       String  @db.Text
  imageUrl     String  @map("image_url")
  thumbnailUrl String? @map("thumbnail_url")
  metadata     Json? // Paper Banana response metadata

  // Quality
  qualityScore Float?  @map("quality_score") // Paper Banana Critic evaluation (0-100)
  altText      String? @map("alt_text") // SEO alt text
  caption      String?

  // Status
  status String @default("generated") // 'generated', 'approved', 'published'

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([reportId])
  @@index([type])
  @@map("visual_assets")
}

model LocalCaseStudy {
  id     Int    @id @default(autoincrement())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  title String
  slug  String @unique

  // Location
  suburb      String
  city        String
  state       String
  postcode    String
  coordinates Json? // {lat, lng}

  // Content sections
  summary     String  @db.Text
  challenge   String? @db.Text
  solution    String? @db.Text
  results     String? @db.Text
  testimonial String? @db.Text

  // Visuals
  beforeImages String[] @map("before_images")
  afterImages  String[] @map("after_images")
  diagrams     String[] // Paper Banana generated URLs

  // Schema & SEO
  schemaMarkup Json? @map("schema_markup") // LocalBusiness + Service schema
  napData      Json? @map("nap_data") // {name, address, phone} for consistency checking

  // Timestamps
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([city, state])
  @@map("local_case_studies")
}

model ArticleAuthor {
  id       Int           @id @default(autoincrement())
  postId   String        @map("post_id") // References Post.id (cuid)
  authorId Int           @map("author_id")
  author   AuthorProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  role     String        @default("author") // 'author', 'reviewer', 'contributor'

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, authorId])
  @@index([postId])
  @@index([authorId])
  @@map("article_authors")
}

// ==========================================
// Multi-Business Owner System
// Allows custom-plan users to own and manage multiple
// organizations (businesses) from a single login.
// Each child business = $249/month additional.
// ==========================================

model BusinessOwnership {
  id             String   @id @default(cuid())
  ownerId        String   @map("owner_id")
  organizationId String   @map("organization_id")
  displayName    String?  @map("display_name") // Owner's custom label
  isActive       Boolean  @default(true) @map("is_active")
  billingStatus  String   @default("active") @map("billing_status") // 'active', 'past_due', 'cancelled'
  monthlyRate    Float    @default(249.0) @map("monthly_rate") // $249/month per business
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  owner        User         @relation("OwnedBusinesses", fields: [ownerId], references: [id], onDelete: Cascade)
  organization Organization @relation("BusinessOwners", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([ownerId, organizationId])
  @@index([ownerId])
  @@index([organizationId])
  @@map("business_ownerships")
}

// ==========================================
// Social Listening System
// Track brand mentions, keywords, and hashtags
// across social platforms.
// ==========================================

model TrackedKeyword {
  id             String  @id @default(cuid())
  userId         String  @map("user_id")
  organizationId String? @map("organization_id")

  keyword   String // The keyword or hashtag (without #)
  type      String // 'keyword', 'hashtag', 'mention', 'brand'
  platforms String[] // Which platforms to monitor
  isActive  Boolean  @default(true) @map("is_active")

  // Tracking stats
  lastCheckedAt DateTime? @map("last_checked_at")
  totalMentions Int       @default(0) @map("total_mentions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization?   @relation(fields: [organizationId], references: [id])
  mentions     SocialMention[]

  @@index([userId])
  @@index([organizationId])
  @@index([keyword])
  @@index([isActive])
  @@map("tracked_keywords")
}

model SocialMention {
  id        String @id @default(cuid())
  keywordId String @map("keyword_id")
  userId    String @map("user_id")

  // Platform info
  platform       String // 'twitter', 'instagram', etc.
  platformPostId String  @map("platform_post_id")
  platformUrl    String? @map("platform_url")

  // Author info
  authorHandle    String  @map("author_handle")
  authorName      String? @map("author_name")
  authorAvatar    String? @map("author_avatar")
  authorFollowers Int?    @map("author_followers")

  // Content
  content   String   @db.Text
  mediaUrls String[] @map("media_urls")

  // Metrics
  likes    Int  @default(0)
  comments Int  @default(0)
  shares   Int  @default(0)
  reach    Int? // Estimated reach

  // Analysis
  sentiment      String? // 'positive', 'negative', 'neutral'
  sentimentScore Float?  @map("sentiment_score") // -1.0 to 1.0
  isInfluencer   Boolean @default(false) @map("is_influencer")

  // Status
  isRead     Boolean @default(false) @map("is_read")
  isArchived Boolean @default(false) @map("is_archived")
  isFlagged  Boolean @default(false) @map("is_flagged")

  postedAt  DateTime @map("posted_at")
  fetchedAt DateTime @default(now()) @map("fetched_at")
  createdAt DateTime @default(now()) @map("created_at")

  keyword TrackedKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, platformPostId])
  @@index([keywordId])
  @@index([userId])
  @@index([platform])
  @@index([sentiment])
  @@index([postedAt])
  @@index([isRead])
  @@map("social_mentions")
}

// ==========================================
// Link in Bio Pages
// Customizable landing pages for social profiles
// ==========================================

model LinkBioPage {
  id     String @id @default(cuid())
  userId String @map("user_id")

  // Page identity
  slug  String  @unique // URL-friendly identifier
  title String // Display name
  bio   String? @db.Text // Short bio/description

  // Profile
  avatarUrl String? @map("avatar_url")
  coverUrl  String? @map("cover_url")

  // Theme settings
  theme           String @default("default") // 'default', 'minimal', 'gradient', 'dark', 'neon', 'forest'
