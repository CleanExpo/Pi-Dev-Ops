// ==========================================

/// Running instance of a WorkflowTemplate - tracks execution state.
/// Supports parallel step execution, human approval gates, and auto-rollback.
/// Status flow: pending → running → waiting_approval → completed/failed.
model WorkflowExecution {
  id               String          @id @default(cuid())
  organizationId   String          @map("organization_id")
  workflowId       String?         @map("workflow_id")
  status           String          @default("pending")
  // pending | running | waiting_approval | completed | failed | cancelled
  title            String
  triggerType      String          @default("manual") @map("trigger_type")
  // manual | scheduled | api | cron
  triggeredBy      String          @map("triggered_by")
  currentStepIndex Int             @default(0) @map("current_step_index")
  totalSteps       Int             @default(0) @map("total_steps")
  inputData        Json?           @map("input_data")
  outputData       Json?           @map("output_data")
  errorMessage     String?         @map("error_message")
  startedAt        DateTime?       @map("started_at")
  completedAt      DateTime?       @map("completed_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  // Phase 63: batch execution grouping
  batchId          String?         @map("batch_id")
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stepExecutions   StepExecution[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([batchId])
  @@map("workflow_executions")
}

model StepExecution {
  id                  String            @id @default(cuid())
  workflowExecutionId String            @map("workflow_execution_id")
  stepIndex           Int               @map("step_index")
  stepName            String            @map("step_name")
  stepType            String            @map("step_type")
  // ai | approval | action | validation
  status              String            @default("pending")
  // pending | running | completed | failed | skipped | waiting_approval
  inputData           Json?             @map("input_data")
  outputData          Json?             @map("output_data")
  confidenceScore     Float?            @map("confidence_score")
  autoApproved        Boolean           @default(false) @map("auto_approved")
  approvedBy          String?           @map("approved_by")
  approvedAt          DateTime?         @map("approved_at")
  errorMessage        String?           @map("error_message")
  retryCount          Int               @default(0) @map("retry_count")
  startedAt           DateTime?         @map("started_at")
  completedAt         DateTime?         @map("completed_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  workflowExecution   WorkflowExecution @relation(fields: [workflowExecutionId], references: [id], onDelete: Cascade)

  @@index([workflowExecutionId])
  @@index([workflowExecutionId, stepIndex])
  @@map("step_executions")
}

