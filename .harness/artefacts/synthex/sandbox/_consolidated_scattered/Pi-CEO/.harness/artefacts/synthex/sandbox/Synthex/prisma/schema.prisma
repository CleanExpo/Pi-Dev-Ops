  responseStatus  String    @default("pending") @map("response_status") // pending | posted | dismissed
  dismissReason   String?   @map("dismiss_reason") // too_formal | wrong_tone | inaccurate | other

  // Moderation + widget (UNI-1642)
  status              String    @default("approved") @map("status") // approved | pending | rejected | hidden
  isFeatured          Boolean   @default(false) @map("is_featured")
  displayOnWidget     Boolean   @default(true) @map("display_on_widget")
