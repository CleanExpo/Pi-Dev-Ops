/// Tracks review requests sent to clients post-job.
/// Used to automate review generation loop and follow-up cadence.
model ReviewRequest {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  locationId     String    @map("location_id")
  recipientName  String    @map("recipient_name")
  recipientEmail String    @map("recipient_email")
  reviewLink     String    @map("review_link")
  recipientPhone  String?   @map("recipient_phone")
  channel         String    @default("email") @map("channel") // email | sms
  status         String    @default("pending") @map("status") // pending | followed_up | completed
  sentAt         DateTime  @default(now()) @map("sent_at")
  followUpSentAt DateTime? @map("follow_up_sent_at")
  reviewReceivedAt DateTime? @map("review_received_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("review_requests")
}

/// GSC-derived keyword opportunities surfaced as content topic suggestions.
/// Populated weekly by gsc-topic-sync cron. Consumed by content generator
/// when no explicit topic is provided.
model ContentTopicSuggestion {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  keyword          String
  impressions      Int       @default(0)
  currentRank      Float     @default(0) @map("current_rank")
  opportunityScore Float     @default(0) @map("opportunity_score")
  usedAt           DateTime? @map("used_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, keyword])
  @@index([organizationId])
  @@index([organizationId, usedAt])
  @@map("content_topic_suggestions")
}

// ============================================================================
// SEO Rank Tracking + Visibility Score (SYN-476 + SYN-473)
// ============================================================================

/// User-defined keyword targets for rank tracking.
/// Max 20 per org. Each keyword gets snapshotted weekly from GSC.
model KeywordTarget {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  keyword        String
  location       String? // suburb/city modifier (e.g. "Parramatta NSW")
  isActive       Boolean  @default(true) @map("is_active")
  autoSeeded     Boolean  @default(false) @map("auto_seeded") // true = created by GBP keyword seeder
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  snapshots    KeywordRankSnapshot[]

  @@unique([organizationId, keyword])
  @@index([organizationId])
  @@map("keyword_targets")
}

/// Weekly GSC rank snapshot per keyword target.
/// position null = not found in top 100 (query not matching GSC data).
model KeywordRankSnapshot {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  keywordTargetId String   @map("keyword_target_id")
  position        Float? // null = not in top 100
  impressions     Int?
  clicks          Int?
  ctr             Float?
  snapshotDate    DateTime @map("snapshot_date") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  keywordTarget KeywordTarget @relation(fields: [keywordTargetId], references: [id], onDelete: Cascade)

  @@unique([keywordTargetId, snapshotDate])
  @@index([organizationId, snapshotDate])
  @@index([keywordTargetId])
  @@map("keyword_rank_snapshots")
}

/// Composite visibility score (0–100) for an organisation.
/// Recalculated on: new review, content publish, rank snapshot, GBP update.
model VisibilityScore {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  score          Int // 0–100
  reviewScore    Int      @map("review_score") // 0–40
  gbpScore       Int      @map("gbp_score") // 0–20
  contentScore   Int      @map("content_score") // 0–20
  rankScore      Int      @map("rank_score") // 0–20
  calculatedAt   DateTime @default(now()) @map("calculated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, calculatedAt])
  @@map("visibility_scores")
}

// Platform Integration Models

/// OAuth connection to a social media platform (9 supported).
/// Stores encrypted tokens for API access and handles token refresh.
/// Supports both personal accounts and business pages.
model PlatformConnection {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  organizationId       String?   @map("organization_id") // NULL = personal, non-NULL = business-scoped
  platform             String // 'facebook', 'instagram', 'twitter', 'linkedin', 'tiktok', 'youtube', 'pinterest', 'reddit'
  accessToken          String    @map("access_token")
  refreshToken         String?   @map("refresh_token")
  encryptionKeyVersion Int       @default(1) @map("encryption_key_version") // For key rotation — QA-AUDIT-2026-03-14
  expiresAt            DateTime? @map("expires_at")
  scope                String? // Platform-specific permissions
  profileId            String?   @map("profile_id") // Platform user/page ID
  profileName          String?   @map("profile_name") // Platform username/page name
  accountType          String    @default("personal") @map("account_type") // 'personal' | 'business_page' | 'company'
  isActive             Boolean   @default(true) @map("is_active")
  lastSync             DateTime? @map("last_sync")
  metadata             Json? // Platform-specific data
  deletedAt            DateTime? @map("deleted_at") // Soft delete — QA-AUDIT-2026-03-14
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  platformPosts PlatformPost[]

  // One connection per platform per organization (or per user if no org)
  @@unique([userId, platform, organizationId], name: "unique_user_platform_org")
  @@index([organizationId, platform])
  @@index([deletedAt])
  @@map("platform_connections")
}

model PlatformPost {
  id           String    @id @default(cuid())
  connectionId String    @map("connection_id")
  platformId   String    @map("platform_id") // ID on the platform
  content      String    @db.Text
  mediaUrls    String[]  @map("media_urls")
  hashtags     String[]
  mentions     String[]
  status       String    @default("draft") // 'draft', 'scheduled', 'published', 'failed'
  scheduledAt  DateTime? @map("scheduled_for")
  publishedAt  DateTime? @map("published_at")
  errorMessage String?   @map("error_message")
  metadata     Json? // Platform-specific post data
  deletedAt    DateTime? @map("deleted_at") // Soft delete — QA-AUDIT-2026-03-14
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  connection PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  metrics    PlatformMetrics[]

  @@unique([connectionId, platformId])
  @@index([deletedAt])
  @@map("platform_posts")
}

model PlatformMetrics {
  id             String   @id @default(cuid())
  postId         String   @map("post_id")
  likes          Int      @default(0)
  shares         Int      @default(0)
  comments       Int      @default(0)
  views          Int      @default(0)
  reach          Int      @default(0)
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  saves          Int      @default(0)
  engagementRate Float?   @map("engagement_rate")
  metadata       Json? // Platform-specific metrics
  recordedAt     DateTime @default(now()) @map("recorded_at")

  // Relations
  post PlatformPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Performance indices for analytics queries
  @@index([postId, recordedAt(sort: Desc)])
  @@index([recordedAt])
  @@map("platform_metrics")
}

//
// Team invitations (persistence for /api/teams/invite)
//
model TeamInvitation {
  id             String   @id @default(cuid())
  email          String
  role           String
