// ==========================================
// UNI-1592 — ON DELETE CASCADE + UNI-1594 — Performance indexes
// New founder-scoped models
// ==========================================

/// SEO-specific content type variants (SYN-475).
/// Drives structure-aware article prompts and layout rendering.
enum SeoContentType {
  blog_local_authority
  how_to
  listicle
  news_item
  comparison
  case_study
}

/// AI-generated content items owned by a user (founder).
/// onDelete: Cascade — deleting the user removes all their generated content.
model GeneratedContent {
  id             String          @id @default(cuid())
  founderId      String          @map("founder_id")
  title          String
  contentType    String          @map("content_type") // 'post' | 'email' | 'script' | 'ad' | 'caption'
  seoContentType SeoContentType? @map("seo_content_type") // SYN-475
  body           String          @db.Text
  layoutData     Json?           @map("layout_data") // Structured sections (SYN-475)
  metadata       Json? // platform, tone, model used, etc.
  status         String          @default("draft") // draft | published | archived
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  founder User @relation(fields: [founderId], references: [id], onDelete: Cascade)

  @@index([founderId])
  @@index([founderId, status, createdAt])
  @@map("generated_content")
}

/// Video assets generated or uploaded by a user (founder).
/// onDelete: Cascade — deleting the user removes all their video assets.
model VideoAsset {
  id        String   @id @default(cuid())
  founderId String   @map("founder_id")
  title     String
  url       String // Storage URL
  thumbnail String? // Thumbnail URL
  duration  Int? // seconds
  status    String   @default("pending") // pending | processing | ready | failed
  metadata  Json? // resolution, codec, size, etc.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  founder User @relation(fields: [founderId], references: [id], onDelete: Cascade)

  @@index([founderId])
  @@index([founderId, status])
