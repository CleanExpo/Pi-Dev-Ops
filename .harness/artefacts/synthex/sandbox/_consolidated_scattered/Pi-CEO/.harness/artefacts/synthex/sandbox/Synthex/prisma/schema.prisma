// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

/// Core user account - the primary identity for authentication and ownership.
/// Supports local auth (email/password) and OAuth providers via Account relation.
/// All business entities (campaigns, posts, subscriptions) link back to User.
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String? // Nullable for OAuth-only users
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Legacy Google OAuth fields (deprecated - use Account model)
  // Keep temporarily for migration
  googleId      String?   @unique @map("google_id")
  avatar        String?
  authProvider  String    @default("local") @map("auth_provider") // 'local', 'google'
  emailVerified Boolean?  @default(false) @map("email_verified") // Boolean indicating if email is verified
  lastLogin     DateTime? @map("last_login")

  // API Keys (encrypted)
  openrouterApiKey String? @map("openrouter_api_key")
  anthropicApiKey  String? @map("anthropic_api_key")
  openaiApiKey     String? @map("openai_api_key")
  geminiApiKey     String? @map("gemini_api_key")

  // Profile fields (migrated from Supabase profiles table)
  company     String?
  jobRole     String? @map("job_role")
  bio         String?
  phone       String?
  website     String?
  socialLinks Json?   @map("social_links")

  // User settings (stores notification, privacy, theme preferences)
  preferences Json?
  settings    Json? @map("user_settings") // Migrated from Supabase user_settings table

  // Password reset fields
  resetCode         String?   @map("reset_code")
  resetCodeExpires  DateTime? @map("reset_code_expires")
  resetToken        String?   @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")

  // Email verification
  verificationCode    String?   @map("verification_code")
  verificationExpires DateTime? @map("verification_expires")

  // Relations
  accounts              Account[] // Multi-provider authentication accounts
  campaigns             Campaign[]
  projects              Project[]
  apiUsage              ApiUsage[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  platformConnections   PlatformConnection[]
  organizationId        String?                   @map("organization_id")
  organization          Organization?             @relation(fields: [organizationId], references: [id])
  teamInvitations       TeamInvitation[]
  teamMemberships       TeamMember[]    @relation("TeamMemberUser")
  teamMembersInvited    TeamMember[]    @relation("TeamMemberInviter")
  brandGenerations      BrandGeneration[]
  psychologyPreferences UserPsychologyPreference?
  reports               Report[]

  // Retention system relations
  aiConversations  AIConversation[]
  aiWeeklyDigests  AIWeeklyDigest[]
  healthScore      UserHealthScore?
  streak           UserStreak?
  achievements     UserAchievement[]
  referralsMade    Referral[]        @relation("ReferrerReferrals")
  referralReceived Referral?         @relation("RefereeReferral")
  loyaltyTier      UserLoyaltyTier?
  feedbackSurveys  FeedbackSurvey[]

  // GEO / E-E-A-T / Paper Banana relations
  authorProfiles        AuthorProfile[]
  seoAudits             SEOAudit[]
  scheduledAuditTargets ScheduledAuditTarget[]
  geoAnalyses           GEOAnalysis[]
  entityAnalyses        EntityAnalysis[]
  researchReports       GEOResearchReport[]
  visualAssets          VisualAsset[]
  localCaseStudies      LocalCaseStudy[]

  // Content library
  contentLibrary ContentLibrary[]
  contentDrafts  ContentDraft[]

  // Prompt templates
  promptTemplates PromptTemplate[]

  // Webhook subscriptions
  webhookEndpoints WebhookEndpoint[]

  // Approval workflows
  submittedApprovals ApprovalRequest[] @relation("SubmittedApprovals")

  // Multi-business owner system
  isMultiBusinessOwner Boolean             @default(true) @map("is_multi_business_owner")
  activeOrganizationId String?             @map("active_organization_id")
  ownedBusinesses      BusinessOwnership[] @relation("OwnedBusinesses")

  // Social listening
  trackedKeywords TrackedKeyword[]
  socialMentions  SocialMention[]

  // Link in Bio
  linkBioPages LinkBioPage[]

  // Revenue tracking
  revenueEntries RevenueEntry[]

  // ROI tracking
  contentInvestments ContentInvestment[]

  // Sponsor CRM
  sponsors Sponsor[]

  // Affiliate links
  affiliateNetworks AffiliateNetwork[]
  affiliateLinks    AffiliateLink[]

  // Business vetting & API credentials
  vettingResults           BusinessVettingResult[]
  apiCredentials           APICredential[]
  platformOAuthCredentials PlatformOAuthCredential[] @relation("PlatformOAuthConfiguredBy")
  onboardingProgress       OnboardingProgress[]

  // Video generation
  videoGenerations VideoGeneration[]

  // Marketing Agency
  createdMarketingAgencyCampaigns      MarketingAgencyCampaign[]      @relation("MarketingAgencyCampaignCreator")
  createdMarketingAgencySourceRefs     MarketingAgencySourceRef[]     @relation("MarketingAgencySourceRefCreator")
  createdMarketingAgencyClaims         MarketingAgencyClaim[]         @relation("MarketingAgencyClaimCreator")
  createdMarketingAgencyAssets         MarketingAgencyAsset[]         @relation("MarketingAgencyAssetCreator")
  createdMarketingAgencyQaReports      MarketingAgencyQaReport[]      @relation("MarketingAgencyQaReportCreator")
  createdMarketingAgencyExportPackages MarketingAgencyExportPackage[] @relation("MarketingAgencyExportPackageCreator")

  // Authority Engine (Phase 86)
  authorityAnalyses AuthorityAnalysis[]
  citationMonitors  CitationMonitor[]

  // Writing Methodology (Phase 88)
  voiceProfiles   VoiceProfile[]
  contentCapsules ContentCapsule[]

  // Content Quality Gate (Phase 89)
  contentQualityAudits ContentQualityAudit[]

  // E-E-A-T Score Builder (Phase 90)
  eeatAudits EEATAudit[]

  // Brand Builder (Phase 91)
  brandIdentities BrandIdentity[]

  // PR Journalist CRM (Phase 92)
  journalistContacts JournalistContact[]
  prPitches          PRPitch[]
  mediaCoverage      MediaCoverage[]
  pressReleases      PressRelease[]

  // Award & Directory Orchestrator (Phase 94)
  awardListings      AwardListing[]
  directoryListings  DirectoryListing[]
  submissionTrackers SubmissionTracker[]

  // AI Backlink Prospector (Phase 95)
  backlinkProspects BacklinkProspect[]
  backlinkAnalyses  BacklinkAnalysis[]

  // Prompt Intelligence (Phase 96)
  promptTrackers PromptTracker[]

  // Algorithm Sentinel (Phase 97)
  siteHealthSnapshots SiteHealthSnapshot[]
  sentinelAlerts      SentinelAlert[]

  // Autonomous A/B Testing & Self-Healing Agent (Phase 98)
  seoExperiments SEOExperiment[]
  healingActions HealingAction[]

  // Adaptive Intelligence Engine (BO + Prophet + BayesNF)
  boSpaces             BOSpace[]
  boRuns               BOOptimisationRun[]
  forecastModels       ForecastModel[]
  spatiotemporalModels SpatiotemporalModel[]

  // Vault — secrets created by this user
  createdVaultSecrets VaultSecret[] @relation("VaultSecretCreator")

  // UNI-1592/1594 — founder-scoped models
  generatedContents GeneratedContent[]
  videoAssets       VideoAsset[]
  socialEngagements SocialEngagement[]
  emailCampaigns    EmailCampaign[]
  platformAnalytics PlatformAnalytic[]
  advisoryCases     AdvisoryCase[]
  experiments       Experiment[]
  credentialsVaults CredentialsVault[]
  nexusDatabases    NexusDatabase[]
  connectedProjects ConnectedProject[]

  // Onboarding state (UNI-920)
  onboardingComplete      Boolean   @default(false) @map("onboarding_complete")
  onboardingStep          Int       @default(0) @map("onboarding_step") // 0=not started, 1=business, 2=api-key, 3=socials, 4=goals
  businessProfileComplete Boolean   @default(false) @map("business_profile_complete")
  apiKeyConfigured        Boolean   @default(false) @map("api_key_configured")
  apiKeyValid             Boolean   @default(false) @map("api_key_valid")
  apiKeyLastValidated     DateTime? @map("api_key_last_validated")
  timezone                String    @default("Australia/Brisbane")
  deletedAt               DateTime? @map("deleted_at") // Soft delete — QA-AUDIT-2026-03-14
  referralCode            String?   @unique @map("referral_code") // Stored random code — SYN-424

  @@index([organizationId])
  @@index([onboardingComplete])
  @@index([deletedAt])
  @@map("users")
}

// ==========================================
// OAuth Account Model for Multi-Provider Authentication
// Supports linking multiple auth methods to a single user
// ==========================================

model Account {
  id                String @id @default(uuid())
  userId            String @map("userId")
  type              String // "oauth" or "credentials"
  provider          String // "google", "github", "email"
  providerAccountId String @map("providerAccountId") // Google ID, GitHub ID, or email

  // OAuth tokens (encrypted at rest in production)
  // Column names use snake_case in database
  accessToken  String? @map("access_token") @db.Text
  refreshToken String? @map("refresh_token") @db.Text
  expiresAt    Int?    @map("expires_at") // Unix timestamp
  tokenType    String? @map("token_type") // "Bearer", etc.
  scope        String? // OAuth scopes granted
  idToken      String? @map("id_token") @db.Text // OIDC ID token
  sessionState String? @map("session_state") // OIDC session state

  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Constraints
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Marketing campaign container - organises posts, content, and analytics.
/// Targets a specific platform with AI-generated content variations.
/// Tracks performance metrics and A/B test results.
model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  platform    String // 'instagram', 'twitter', 'linkedin', etc.
  status      String   @default("draft") // 'draft', 'active', 'paused', 'completed'
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Campaign data
  content   Json? // Generated content, variations, etc.
  analytics Json? // Performance metrics
  settings  Json? // Platform-specific settings
  deletedAt DateTime? @map("deleted_at") // Soft delete — QA-AUDIT-2026-03-14

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts  Post[]

  // Organization (multi-tenant)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation("OrganizationCampaigns", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("campaigns")
}

/// Individual social media post - the atomic unit of content.
/// Supports scheduling, multi-platform publishing, and engagement tracking.
/// Links to PlatformPost for platform-specific metadata after publishing.
model Post {
  id          String    @id @default(cuid())
  content     String
  platform    String
  status      String    @default("draft")
  // Legal values: 'draft' | 'scheduled' | 'published' | 'failed' | 'pending_approval'.
  // 'pending_approval' added for HERMES-originated drafts (HER-1a / SYN-909).
  // Not enforced at DB level to avoid breaking existing free-string usage —
  // enforced at application layer via Zod in the scheduler route.
  source      String?   // 'hermes' | 'autopilot' | null (legacy / human).
  // Nullable by design: existing posts carry null (= 'human').
  // HERMES writes 'hermes'. Autopilot may be promoted from metadata in a later ticket.
  scheduledAt DateTime? @map("scheduled_at")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Post data
  metadata  Json? // Images, hashtags, mentions, etc.
  analytics Json? // Engagement metrics
  deletedAt DateTime? @map("deleted_at") // Soft delete — QA-AUDIT-2026-03-14

  // Relations
  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // HERMES proposal back-relation (optional 1:1 — populated when HERMES wrote this post).
  hermesProposal HermesProposal? @relation("HermesProposalPost")

  // Performance indices for common queries
  @@index([campaignId, createdAt(sort: Desc)])
  @@index([platform, status])
  @@index([scheduledAt])
  @@index([deletedAt])
  @@index([source, status]) // HER-1a: HERMES metrics queries (source='hermes' AND status='published')
  @@map("posts")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String // 'marketing', 'content', 'analytics', 'webdesign'
  data        Json? // Project configuration and data
  status      String   @default("draft") // 'draft', 'active', 'archived'
  websiteUrl  String?  @map("website_url")
  domain      String?
  pages       Int?
  colors      Json? // Array of hex colour strings
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  userId         String        @map("user_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation("OrganizationProjects", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([organizationId])
  @@map("projects")
}

model ApiUsage {
  id        String   @id @default(cuid())
  endpoint  String
  model     String? // AI model used
  tokens    Int? // Tokens consumed
  cost      Float? // Cost in USD
  status    String // 'success', 'error', 'rate_limited'
  createdAt DateTime @default(now()) @map("created_at")

  // Request/Response data
  requestData  Json?   @map("request_data")
  responseData Json?   @map("response_data")
  errorMessage String? @map("error_message")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("api_usage")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sessions")
}

// OAuth PKCE state storage — survives serverless cold starts
// Replaces in-memory Map that fails across Vercel workers
model OAuthPKCEState {
  id           String   @id @default(cuid())
  state        String   @unique
  codeVerifier String   @map("code_verifier")
  provider     String // 'google', 'github', etc.
  redirectUri  String   @map("redirect_uri")
  linkToUserId String?  @map("link_to_user_id")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("oauth_pkce_states")
}

model Notification {
  id        String   @id @default(cuid())
  type      String // 'info', 'warning', 'error', 'success'
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json? // Additional notification data
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read, createdAt])
  @@map("notifications")
}

model WebhookEndpoint {
  id              String    @id @default(cuid())
  url             String
  secret          String
  description     String?
  events          Json // Array of WebhookEventType strings stored as JSON
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lastDeliveredAt DateTime? @map("last_delivered_at")
  failureCount    Int       @default(0) @map("failure_count")
  metadata        Json? // Additional config (headers, timeout overrides)

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, active])
  @@map("webhook_endpoints")
}

// AI model performance metrics — SYN-486
model ModelMetric {
  id           String   @id @default(cuid())
  modelId      String   @map("model_id")
  provider     String
  contentType  String   @map("content_type")
  requestCount Int      @default(0) @map("request_count")
  totalTokens  Int      @default(0) @map("total_tokens")
  totalCostUsd Float    @default(0) @map("total_cost_usd")
  avgLatencyMs Int?     @map("avg_latency_ms")
  errorCount   Int      @default(0) @map("error_count")
  qualityScore Float?   @map("quality_score")
  weekStart    DateTime @map("week_start") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([modelId, contentType, weekStart])
  @@index([provider, weekStart])
  @@map("model_metrics")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String // 'user_login', 'post_publish', 'password_change', etc.
  resource   String // 'authentication', 'user', 'post', 'api_key', etc.
  resourceId String?  @map("resource_id") // ID of the affected resource
  entity     String? // Backward compatibility - deprecated
  entityId   String?  @map("entity_id") // Backward compatibility - deprecated
  details    Json? // Additional details about the action
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  severity   String   @default("medium") // 'low', 'medium', 'high', 'critical'
  category   String   @default("system") // 'auth', 'data', 'system', 'security', 'compliance', 'api'
  outcome    String   @default("success") // 'success', 'failure', 'warning'
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([category])
  @@map("audit_logs")
}

/// Multi-tenant business entity - groups users, campaigns, and resources.
/// Supports tiered plans (free/starter/pro/enterprise) with feature limits.
/// Can have custom domains for white-label deployments.
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?

  // Workspace umbrella (SYN-847 Unite-Group multi-brand)
  // Self-FK: a child org points at its parent (workspace) org.
  // Parent orgs have parentOrgId === null. Children have it populated.
  // Backward-compatible — existing single-tenant orgs stay parentOrgId=null.
  parentOrgId String?       @map("parent_org_id")
  parent      Organization? @relation("OrgWorkspace", fields: [parentOrgId], references: [id])
  children    Organization[] @relation("OrgWorkspace")
  plan        String   @default("free") // 'free', 'starter', 'pro', 'enterprise'
  status      String   @default("active") // 'active', 'suspended', 'pending', 'deleted'
  settings    Json? // Organization-wide settings

  // Engagement milestones — SYN-525
  firstWinDetected Boolean @default(false) @map("first_win_detected")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Domain configuration (multi-tenant)
  domain       String? @unique // Primary subdomain (e.g., acme.synthex.app)
  customDomain String? @unique @map("custom_domain") // Custom domain (e.g., marketing.acme.com)

  // Business identity
  website     String?
  industry    String?
  abn         String? // Australian Business Number
  teamSize    String? @map("team_size")
  phoneNumber String? @map("phone_number")

  // AI-generated metadata
  aiGeneratedData Json? @map("ai_generated_data") // Full AI analysis snapshot
  socialHandles   Json? @map("social_handles") // { twitter: "@handle", ... }

  // Branding
  logo         String?
  primaryColor String? @map("primary_color")
  favicon      String?

  // Billing
  stripeCustomerId String? @map("stripe_customer_id")
  billingEmail     String? @map("billing_email")
  billingStatus    String  @default("active") @map("billing_status") // 'active', 'past_due', 'canceled'

  // Usage limits
  maxUsers     Int @default(5) @map("max_users")
  maxPosts     Int @default(500) @map("max_posts")
  maxCampaigns Int @default(10) @map("max_campaigns")

  // Relations
  users           User[]
  teamInvitations TeamInvitation[]
  teamMembers     TeamMember[]
  roles           Role[]
  campaigns       Campaign[]          @relation("OrganizationCampaigns")
  projects        Project[]           @relation("OrganizationProjects")
  businessOwners  BusinessOwnership[] @relation("BusinessOwners")
  promptTemplates PromptTemplate[]

  // Approval workflows
  approvalRequests  ApprovalRequest[]
  workflowTemplates WorkflowTemplate[]

  // Social listening
  trackedKeywords TrackedKeyword[]

  // Platform connections (business-scoped social accounts)
  platformConnections PlatformConnection[]

  // Business vetting & API credentials
  vettingResults     BusinessVettingResult[]
  apiCredentials     APICredential[]
  onboardingProgress OnboardingProgress[]

  // Video generation
  videoGenerations VideoGeneration[] @relation("OrganizationVideos")

  // Marketing Agency
  marketingAgencyCampaigns      MarketingAgencyCampaign[]      @relation("MarketingAgencyCampaignOrganization")
  marketingAgencySourceRefs     MarketingAgencySourceRef[]     @relation("MarketingAgencySourceRefOrganization")
  marketingAgencyClaims         MarketingAgencyClaim[]         @relation("MarketingAgencyClaimOrganization")
  marketingAgencyAssets         MarketingAgencyAsset[]         @relation("MarketingAgencyAssetOrganization")
  marketingAgencyQaReports      MarketingAgencyQaReport[]      @relation("MarketingAgencyQaReportOrganization")
  marketingAgencyExportPackages MarketingAgencyExportPackage[] @relation("MarketingAgencyExportPackageOrganization")
  marketingAgencySignals        MarketingAgencySignal[]        @relation("MarketingAgencySignalOrganization")
  marketingAgencyOpportunities  MarketingAgencyOpportunity[]   @relation("MarketingAgencyOpportunityOrganization")
  marketingAgencyOutcomeEvents  MarketingAgencyOutcomeEvent[]  @relation("MarketingAgencyOutcomeEventOrganization")

  // Workflow engine (Phase 62)
  workflowExecutions WorkflowExecution[]

  // PR Journalist CRM (Phase 92)
  journalistContacts JournalistContact[]
  prPitches          PRPitch[]
  mediaCoverage      MediaCoverage[]
  pressReleases      PressRelease[]

  // Vault — centralised secrets management
  vaultSecrets    VaultSecret[]
  vaultAccessLogs VaultAccessLog[]

  // Brand DNA relation
  brandDna        BrandDNA?

  // Tasks (org-scoped)
  tasks Task[] @relation("OrganizationTasks")

  // GEO Research Reports (org-scoped)
  geoResearchReports GEOResearchReport[] @relation("OrganizationGEOReports")

  // Auto-Research System
  autoResearchRuns AutoResearchRun[]
  trendInsights    TrendInsight[]

  // Stickiness — streak tracking
  streakCount     Int      @default(0)
  lastApprovedAt  DateTime?
  longestStreak   Int      @default(0)
  timezone        String   @default("Australia/Sydney")

  // Google Search Console + Business Profile (Phase 128)
  gscProperties GSCProperty[]
  gscSnapshots  GSCSnapshot[]
  gbpLocations  GBPLocation[]
  gbpReviews    GBPReview[]
  gbpSnapshots  GBPSnapshot[]

  // Google Analytics 4 properties — SYN-793
  ga4Properties GA4Property[]

  // Autopilot Engine (Phase 132)
  autopilotConfig AutopilotConfig?
  autopilotRuns   AutopilotRun[]

  // Testimonials (UNI-1637)
  testimonialRequests TestimonialRequest[]
  testimonials        Testimonial[]

  // Review requests (SYN-474)
  reviewRequests ReviewRequest[]

  // Authority Score history — SYN-513
  authorityScores AuthorityScore[]

  // Weekly content calendars — SYN-521
  contentCalendars ContentCalendar[]

  // Auto-publish queue — SYN-523
  publishQueueItems PublishQueueItem[]

  // Calendar autonomy mode — SYN-522
  // 'shadow' = review all posts before publishing (default, safe)
  // 'live' = auto-publish posts at scheduled time
  calendarMode String @default("shadow") @map("calendar_mode")

  // Auto-publish pause — SYN-551
  // Immediately halts all pending auto-publish actions when true
  autoPublishPaused Boolean @default(false) @map("auto_publish_paused")

  // Cancellation feedback — SYN-551
  // too_expensive | not_enough_value | lost_control_of_content | switching_tools | business_closed | other
  cancellationReason String?   @map("cancellation_reason")
  cancelledAt        DateTime? @map("cancelled_at")

  // Progressive Live Mode — SYN-552
  // liveModeT: 0=shadow, 1=tier1 (single best category + time slot), 2=full
  liveModeT                  Int       @default(0) @map("live_mode_tier")
  liveModeActivatedAt        DateTime? @map("live_mode_activated_at")
  perpetualReviewer          Boolean   @default(false) @map("perpetual_reviewer")
  shadowModeApprovalRate     Float     @default(0) @map("shadow_mode_approval_rate")
  consecutiveThresholdPasses Int       @default(0) @map("consecutive_threshold_passes")
  nudgeDismissedAt           Json?     @map("nudge_dismissed_at") // { "30": ISO, "45": ISO, "60": ISO }

  // Monthly Story — SYN-553
  // Day of month (1–28) when the story is delivered relative to billing renewal
  billingAnchorDate Int?            @map("billing_anchor_date") // null → defaults to 28
  monthlyStories             MonthlyStory[]
  storyConfig                StoryConfig?
  seasonalSignalDismissals   SeasonalSignalDismissal[]
  recommendedActions         RecommendedAction[]
  advisorFeedback            AdvisorFeedback[]

  // GSC content topic suggestions (SYN-472)
  contentTopicSuggestions ContentTopicSuggestion[]

  // Keyword rank tracking (SYN-476)
  keywordTargets   KeywordTarget[]
  rankSnapshots    KeywordRankSnapshot[]
  visibilityScores VisibilityScore[]

  // Competitor displacement (SYN-484)
  competitorKeywordGaps CompetitorKeywordGap[]

  // Video production series (SYN-572)
  videoSeries VideoSeries[] @relation("OrganisationVideoSeries")

  // Team invite prompt tracking — SYN-597
  invitePromptDismissedAt  DateTime? @map("invite_prompt_dismissed_at")
  invitePromptDismissCount Int       @default(0) @map("invite_prompt_dismiss_count")

  // Client Health Score history — SYN-611
  clientHealthScores ClientHealthScore[]

  // Lead ground-truth — SYN-794
  leads Lead[]

  // Retention Engine — SYN-614
  healthInterventions  HealthIntervention[]
  founderOutreachQueue FounderOutreachQueue[]

  // Content Learning Loop — SYN-631
  contentPerformanceProfile ContentPerformanceProfile?

  // Content improvement tracking — SYN-632
  contentImprovementTracking ContentImprovementTracking[]

  // HERMES proactive intelligence layer (HER-1a / SYN-909).
  hermesConfig            HermesConfig?
  hermesDiscoverySignals  HermesDiscoverySignal[]
  hermesGapCandidates     HermesGapCandidate[]
  hermesProposals         HermesProposal[]

  // Indices for multi-tenant queries
  @@index([slug])
  @@index([status])
  @@index([plan])
  @@index([parentOrgId]) // SYN-847 workspace umbrella — fast child lookup
  @@map("organizations")
