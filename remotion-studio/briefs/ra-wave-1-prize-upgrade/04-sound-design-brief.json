    "sfx": [
      {"moment": "scene transitions", "type": "restrained whoosh"},
      {"moment": "Accept & Start tap", "type": "UI click/tap"},
      {"moment": "proof numbers", "type": "soft impact sting"},
      {"moment": "final lockup", "type": "brand sting under 1s"}
    ],
    "ambience": {
      "scene_2": "subtle late-night office/room tone",
      "product_scenes": "very light digital ambience, almost subliminal"
    }
  },
  "mix_targets": {
    "integrated_lufs": -14,
    "true_peak_db_tp": -1,
    "sample_rate_hz": 48000,
    "voice_priority": "voice remains intelligible on phone and laptop speakers"
  },
  "qa": [
    "music ducks under every voiceover line",
    "no SFX masks words",
