{
  "job_id": "ra-2026-05-15-wave-1-launch",
  "sound_world": "restrained, confident, forensic, Australian-built",
  "layers": {
    "voiceover": {
      "source": "existing scene MP3s",
      "treatment": ["de-ess if needed", "light compression", "small low-mid warmth", "room-tone bed"]
    },
    "music": {
      "mood": "low tension to confident release",
      "tempo": "slow-to-mid, not hype",
      "licensing": "Artlist/Audio Network/owned library only; no unclear AI music"
