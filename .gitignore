# ── Docker / deployment ───────────────────────────────────────────────
*.pid
*.seed
.env.docker
docker-compose.override.yml

# ── launchd plists with embedded credentials (use .plist.example instead) ──
scripts/*.plist
!scripts/*.plist.example

